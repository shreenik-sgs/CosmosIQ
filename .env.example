# CosmosIQ environment template (IMPLEMENTATION-023B) -- NAMES + placeholder guidance ONLY.
#
# This file lists every env var the system may read. It is the ONLY .env* file that is
# committed. Copy it to a real ".env" and fill in your OWN values there:
#
#     cp .env.example .env    # then edit .env with your real credentials
#
# THE REAL .env IS NEVER COMMITTED. It is gitignored (see .gitignore: `.env` / `.env.*`
# with `!.env.example`); the CI gate (`cosmosiq_ops.ci_gate.check_env_not_tracked`) fails
# if any real .env is ever tracked. Every value below is an OBVIOUSLY-FAKE placeholder:
# there is NO real secret in this file, and there must never be one. CosmosIQ reads only the
# PRESENCE of these vars (name in os.environ) -- a value is never read, logged, or persisted.
#
# A REQUIRED var that is absent BLOCKS the live source it gates (an honest "not configured"
# gap). It never crashes and never silently falls back to fixtures.

# --- SEC EDGAR live source ---------------------------------------------------------------
# Presence-checked identity string that identifies the operator to SEC EDGAR (SEC fair-use
# policy). REQUIRED for the SEC EDGAR live source; absent -> SEC live is blocked.
SEC_USER_AGENT="Your Name your.email@example.com"

# --- FMP live source ---------------------------------------------------------------------
# Presence-checked Financial Modeling Prep API key. REQUIRED for the FMP live source;
# absent -> FMP live is blocked.
FMP_API_KEY="<your-fmp-api-key>"

# --- Alert delivery (email) --------------------------------------------------------------
# Presence-checked email credentials for external alert delivery (020E). REQUIRED only for
# a production-delivery posture; absent -> external email delivery stays suppressed (the
# in-app inbox always works). Never a real password here -- a placeholder only.
COSMOSIQ_ALERT_EMAIL_SENDER="alerts@example.com"
COSMOSIQ_ALERT_EMAIL_HOST="smtp.example.com:587"
COSMOSIQ_ALERT_EMAIL_RECIPIENT="you@example.com"
